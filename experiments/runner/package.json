{
  "name": "gs-experiment-runner",
  "version": "1.0.0",
  "description": "Automated runner for the GS vs. Plain-AI RealWorld experiment",
  "private": true,
  "type": "module",
  "scripts": {
    "run:control":    "tsx run-experiment.ts --condition control",
    "run:treatment":  "tsx run-experiment.ts --condition treatment",
    "evaluate":       "tsx evaluate.ts",
    "audit":          "tsx audit.ts --condition control && tsx audit.ts --condition treatment"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.0.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
